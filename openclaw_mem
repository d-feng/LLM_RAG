## 11. Configuration Reference

Minimum viable configuration for a new project using this pattern:

```json5
{
  memory: {
    backend: "sqlite",              // or "qmd" for the full hybrid sidecar
    citations: "auto",              // include source path in recall results

    search: {
      provider: "openai",
      model: "text-embedding-3-small",
      fallback: "local",

      query: {
        hybrid: {
          enabled: true,
          vectorWeight: 0.7,
          textWeight: 0.3,
          candidateMultiplier: 4,
          mmr: { enabled: true, lambda: 0.7 },
          temporalDecay: { enabled: true, halfLifeDays: 30 }
        }
      },

      cache: {
        enabled: true,
        maxEntries: 50000
      }
    },

    capture: {
      autoCapture: false,           // explicit opt-in; risky if left on by default
      autoRecall: true,
      captureMaxChars: 500,
      maxPerTurn: 3
    },

    compaction: {
      memoryFlush: {
        enabled: true,
        softThresholdTokens: 4000
      }
    }
  }
}
```

